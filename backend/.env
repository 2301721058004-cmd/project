# Flask Environment
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=123harini5436

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/smart_helmet_db
TEST_MONGO_URI=mongodb://localhost:27017/smart_helmet_test

# File Storage Paths (relative to backend folder)
UPLOAD_FOLDER=uploads
DETECTION_FOLDER=detections
MAX_CONTENT_LENGTH=16777216

# CORS Allowed Origins (comma-separated for production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# YOLO Model Configuration
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE_THRESHOLD=0.25